# SUMM-Cli 配置文件
# 运行 summ config set <KEY> <VALUE> 或直接编辑此文件
# 环境变量会覆盖此文件中的值

# === API Keys ===
# CAIYUN_TOKEN=        # 彩云天气 API Token (https://www.caiyunapp.com/h5/)
# AMAP_API_KEY=        # 高德地图 API Key (https://console.amap.com/dev/key/app)

# === 默认值 ===
# DEFAULT_LONGITUDE=116.4
# DEFAULT_LATITUDE=39.9
