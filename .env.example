# SUMM-Cli 配置文件
# 运行 summ config set <KEY> <VALUE> 或直接编辑此文件
# 环境变量会覆盖此文件中的值

# === API Keys ===
# CAIYUN_TOKEN=        # 彩云天气 API Token (https://www.caiyunapp.com/h5/)
# AMAP_API_KEY=        # 高德地图 API Key (https://console.amap.com/dev/key/app)
# ZHIPU_API_KEY=       # 智谱 AI API Key (https://open.bigmodel.cn/)
# NTFY_TOKEN=          # ntfy 访问 Token

# === 默认值 ===
# DEFAULT_LONGITUDE=116.4
# DEFAULT_LATITUDE=39.9

# === 智谱 AI (vision 插件) ===
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# MULTIMODAL_MODEL=glm-4.6v

# === ntfy 通知 (notify 插件) ===
# NTFY_URL=http://127.0.0.1:8200
# NTFY_TOPIC=zhengming_notify
# NTFY_USER_NAME=jhihjian
# NTFY_TITLE=通知
# NTFY_PRIORITY=default
# NTFY_TAGS=
# NTFY_TIMEOUT=10
